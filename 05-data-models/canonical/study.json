{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/study.json",
  "title": "Study",
  "description": "A clinical trial. Maps to SDTM domain DM (Demographics) and TS (Trial Summary).",
  "type": "object",
  "required": ["study_id", "protocol_number", "title", "short_title", "phase", "status", "sponsor_id", "indication", "target_enrollment"],
  "properties": {
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique study identifier."
    },
    "protocol_number": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Protocol number."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Full study title."
    },
    "short_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Abbreviated study title."
    },
    "phase": {
      "type": "string",
      "pattern": "^(I|II|III|IV|I/II|II/III|NA)$",
      "description": "Study phase."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "activation_pending", "enrolling", "enrollment_complete", "treatment", "follow_up", "suspended", "locked", "completed", "terminated"],
      "description": "Current study lifecycle status."
    },
    "sponsor_id": {
      "type": "string",
      "format": "uuid",
      "description": "Sponsor organization identifier."
    },
    "indication": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Therapeutic indication."
    },
    "therapeutic_area": {
      "type": "string",
      "maxLength": 200,
      "description": "Therapeutic area (e.g., Oncology)."
    },
    "target_enrollment": {
      "type": "integer",
      "minimum": 0,
      "description": "Planned number of subjects."
    },
    "actual_enrollment": {
      "type": "integer",
      "minimum": 0,
      "description": "Current enrolled subject count."
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Study start date."
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "Study end date."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp."
    }
  }
}

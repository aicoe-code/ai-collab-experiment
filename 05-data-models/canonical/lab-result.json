{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/lab-result.json",
  "title": "LabResult",
  "description": "A laboratory test result. Maps to SDTM domain LB (Laboratory Test Results).",
  "type": "object",
  "required": ["lab_result_id", "subject_id", "study_id", "site_id", "visit_name", "specimen_type", "test_name", "test_code", "result_value", "collection_date"],
  "properties": {
    "lab_result_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique lab result identifier."
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to Subject."
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to parent Study."
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Collection site identifier."
    },
    "visit_name": {
      "type": "string",
      "maxLength": 50,
      "description": "Study visit when sample was collected."
    },
    "specimen_type": {
      "type": "string",
      "maxLength": 100,
      "description": "Type of specimen (blood, urine, etc.)."
    },
    "test_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Laboratory test name."
    },
    "test_code": {
      "type": "string",
      "maxLength": 50,
      "description": "Laboratory test code."
    },
    "result_value": {
      "type": "string",
      "maxLength": 100,
      "description": "Result value (numeric or text)."
    },
    "unit": {
      "type": "string",
      "maxLength": 50,
      "description": "Unit of measurement."
    },
    "reference_range_low": {
      "type": "string",
      "maxLength": 50,
      "description": "Lower limit of normal range."
    },
    "reference_range_high": {
      "type": "string",
      "maxLength": 50,
      "description": "Upper limit of normal range."
    },
    "normal_flag": {
      "type": "string",
      "pattern": "^(NORMAL|HIGH|LOW|ABNORMAL|ND)?$",
      "description": "Normal range flag."
    },
    "collection_date": {
      "type": "string",
      "format": "date",
      "description": "Date specimen was collected."
    },
    "collection_time": {
      "type": "string",
      "maxLength": 20,
      "description": "Time specimen was collected (HH:MM)."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "received", "verified", "query", "resolved", "rejected"],
      "description": "Result verification status."
    },
    "lab_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Performing laboratory name."
    },
    "comments": {
      "type": "string",
      "maxLength": 1000,
      "description": "Result comments."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp."
    }
  }
}

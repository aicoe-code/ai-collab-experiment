{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/visit.json",
  "title": "Visit",
  "description": "A scheduled study visit. Maps to SDTM domain SV (Subject Visits).",
  "type": "object",
  "required": ["visit_id", "study_id", "subject_id", "visit_name", "visit_number", "status"],
  "properties": {
    "visit_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the visit."
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Foreign key to the Study."
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Foreign key to the Subject."
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Foreign key to the Site where visit occurred."
    },
    "visit_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Protocol-defined visit name. CDISC SV variable: VISIT."
    },
    "visit_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential visit number. CDISC SV variable: VISITNUM."
    },
    "visit_scheduled_date": {
      "type": "string",
      "format": "date",
      "description": "Protocol-scheduled date for the visit."
    },
    "visit_actual_date": {
      "type": "string",
      "format": "date",
      "description": "Actual date the visit occurred. CDISC SV variable: SVSTDTC."
    },
    "visit_window_start": {
      "type": "string",
      "format": "date",
      "description": "Earliest acceptable visit date per protocol window."
    },
    "visit_window_end": {
      "type": "string",
      "format": "date",
      "description": "Latest acceptable visit date per protocol window."
    },
    "status": {
      "type": "string",
      "enum": ["SCHEDULED", "IN_PROGRESS", "COMPLETED", "MISSED", "CANCELLED"],
      "description": "Current visit status."
    },
    "visit_type": {
      "type": "string",
      "enum": ["SCREENING", "BASELINE", "TREATMENT", "FOLLOW_UP", "END_OF_STUDY", "UNSCHEDULED"],
      "description": "Category of the visit."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/query.json",
  "title": "Query",
  "description": "A data clarification request (DCR) raised during clinical data review.",
  "type": "object",
  "required": ["query_id", "study_id", "subject_id", "site_id", "crf_page", "field_name", "query_text", "raised_by"],
  "properties": {
    "query_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique query identifier."
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to parent Study."
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to Subject."
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Site associated with the query."
    },
    "crf_page": {
      "type": "string",
      "maxLength": 100,
      "description": "CRF page or form identifier."
    },
    "field_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Data field triggering the query."
    },
    "query_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Query description."
    },
    "status": {
      "type": "string",
      "enum": ["open", "answered", "closed", "cancelled", "reopened"],
      "description": "Current query status."
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Query priority."
    },
    "raised_by": {
      "type": "string",
      "maxLength": 200,
      "description": "Person or system that raised the query."
    },
    "assigned_to": {
      "type": "string",
      "maxLength": 200,
      "description": "Person assigned to resolve."
    },
    "response": {
      "type": "string",
      "maxLength": 2000,
      "description": "Response to the query."
    },
    "responded_by": {
      "type": "string",
      "maxLength": 200,
      "description": "Person who responded."
    },
    "responded_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of response."
    },
    "auto_generated": {
      "type": "boolean",
      "description": "Whether query was auto-generated by system."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/adverse-event.json",
  "title": "AdverseEvent",
  "description": "An adverse event. Maps to SDTM domain AE (Adverse Events).",
  "type": "object",
  "required": ["ae_id", "subject_id", "study_id", "site_id", "term", "severity", "onset_date"],
  "properties": {
    "ae_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique adverse event identifier."
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to affected Subject."
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to parent Study."
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Site where event was reported."
    },
    "term": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Reported adverse event term."
    },
    "meddra_code": {
      "type": "string",
      "maxLength": 20,
      "description": "MedDRA preferred term code."
    },
    "severity": {
      "type": "string",
      "enum": ["mild", "moderate", "severe", "life_threatening", "fatal"],
      "description": "CTCAE severity grade."
    },
    "seriousness": {
      "type": "string",
      "enum": ["serious", "non_serious"],
      "description": "ICH seriousness classification."
    },
    "onset_date": {
      "type": "string",
      "format": "date",
      "description": "Date of AE onset."
    },
    "resolution_date": {
      "type": "string",
      "format": "date",
      "description": "Date of AE resolution."
    },
    "outcome": {
      "type": "string",
      "maxLength": 100,
      "description": "Outcome (recovered, recovering, not recovered, fatal, unknown)."
    },
    "causality": {
      "type": "string",
      "maxLength": 100,
      "description": "Causality assessment (related, not related, unknown)."
    },
    "is_sae": {
      "type": "boolean",
      "description": "Whether event meets SAE criteria."
    },
    "is_susar": {
      "type": "boolean",
      "description": "Whether event is a SUSAR."
    },
    "reported_to_regulator": {
      "type": "boolean",
      "description": "Whether reported to regulatory authority."
    },
    "narrative": {
      "type": "string",
      "maxLength": 5000,
      "description": "Event narrative."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp."
    }
  }
}

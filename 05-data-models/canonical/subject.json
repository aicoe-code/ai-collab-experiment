{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/subject.json",
  "title": "Subject",
  "description": "A participant enrolled in a clinical trial. Maps to SDTM domain DM (Demographics).",
  "type": "object",
  "required": ["subject_id", "study_id", "site_id", "subject_number"],
  "properties": {
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique subject identifier."
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to parent Study."
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Enrolling site identifier."
    },
    "subject_number": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "description": "Subject number within study."
    },
    "status": {
      "type": "string",
      "enum": ["screening", "screened", "enrolled", "randomized", "on_treatment", "completed", "discontinued", "screen_failed", "withdrawn"],
      "description": "Current subject status."
    },
    "screening_date": {
      "type": "string",
      "format": "date",
      "description": "Date of screening visit."
    },
    "enrollment_date": {
      "type": "string",
      "format": "date",
      "description": "Date of formal enrollment."
    },
    "date_of_birth": {
      "type": "string",
      "format": "date",
      "description": "Subject date of birth."
    },
    "sex": {
      "type": "string",
      "pattern": "^(M|F|U)$",
      "description": "Biological sex (M/F/U)."
    },
    "ethnicity": {
      "type": "string",
      "maxLength": 100,
      "description": "Ethnicity."
    },
    "race": {
      "type": "string",
      "maxLength": 100,
      "description": "Race."
    },
    "consent_date": {
      "type": "string",
      "format": "date",
      "description": "Date informed consent was signed."
    },
    "discontinuation_reason": {
      "type": "string",
      "maxLength": 500,
      "description": "Reason for discontinuation."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp."
    }
  }
}

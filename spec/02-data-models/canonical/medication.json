{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/medication.json",
  "title": "Medication",
  "description": "A concomitant or study medication. CDISC SDTM domain: CM.",
  "type": "object",
  "required": [
    "medication_id",
    "subject_id",
    "study_id",
    "drug_name",
    "category",
    "start_date",
    "ongoing"
  ],
  "properties": {
    "medication_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique medication identifier (PK)"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Subject taking the medication (FK → Subject)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study context (FK → Study)"
    },
    "drug_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Name of the medication (CMTRT)"
    },
    "generic_name": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Generic/INN name (CMMODIFY)"
    },
    "who_drug_code": {
      "type": ["string", "null"],
      "maxLength": 20,
      "description": "WHO Drug ATC code (CMDECOD)"
    },
    "category": {
      "type": "string",
      "enum": ["CONCOMITANT", "STUDY_MEDICATION", "PRIOR_MEDICATION"],
      "description": "Medication category (CDISC CT: CMCAT)"
    },
    "dose": {
      "type": ["string", "null"],
      "maxLength": 50,
      "description": "Dose amount and unit (CMDOSTXT)"
    },
    "frequency": {
      "type": ["string", "null"],
      "maxLength": 50,
      "description": "Dosing frequency (CDISC CT: DOSFRQ)"
    },
    "route": {
      "type": ["string", "null"],
      "enum": ["ORAL", "IV", "IM", "SC", "TOPICAL", "INHALED", "OTHER"],
      "description": "Route of administration (CDISC CT: ROUTE)"
    },
    "indication": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Reason for taking the medication (CMINDC)"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Medication start date (CMSTDTC)"
    },
    "end_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Medication end date (CMENDTC, null if ongoing)"
    },
    "ongoing": {
      "type": "boolean",
      "description": "Whether medication is currently ongoing"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp"
    }
  },
  "additionalProperties": false
}

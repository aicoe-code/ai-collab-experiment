{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/lab-result.json",
  "title": "LabResult",
  "description": "A laboratory test result. CDISC SDTM domain: LB.",
  "type": "object",
  "required": [
    "lab_id",
    "subject_id",
    "visit_id",
    "study_id",
    "test_name",
    "test_code",
    "category",
    "unit",
    "collection_date",
    "specimen_type"
  ],
  "properties": {
    "lab_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique lab result identifier (PK)"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Subject this result belongs to (FK → Subject)"
    },
    "visit_id": {
      "type": "string",
      "format": "uuid",
      "description": "Visit at which sample was collected (FK → Visit)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study context (FK → Study)"
    },
    "test_name": {
      "type": "string",
      "maxLength": 100,
      "description": "Name of the lab test (LBTEST)"
    },
    "test_code": {
      "type": "string",
      "maxLength": 20,
      "description": "Lab test code (LBTESTCD)"
    },
    "category": {
      "type": "string",
      "enum": ["CHEMISTRY", "HEMATOLOGY", "URINALYSIS", "IMMUNOLOGY", "OTHER"],
      "description": "Lab category (LBCAT)"
    },
    "result_value": {
      "type": ["number", "null"],
      "description": "Numeric result value (LBSTRESN)"
    },
    "result_text": {
      "type": ["string", "null"],
      "maxLength": 100,
      "description": "Text result for non-numeric values (LBSTRESC)"
    },
    "unit": {
      "type": "string",
      "maxLength": 20,
      "description": "Unit of measurement (CDISC CT: UNIT)"
    },
    "reference_range_low": {
      "type": ["number", "null"],
      "description": "Lower limit of normal range (LBSTNRLO)"
    },
    "reference_range_high": {
      "type": ["number", "null"],
      "description": "Upper limit of normal range (LBSTNRHI)"
    },
    "abnormal_flag": {
      "type": ["string", "null"],
      "enum": ["NORMAL", "LOW", "HIGH", "ABNORMAL"],
      "description": "Normal/abnormal indicator (CDISC CT: LBNRIND)"
    },
    "collection_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date/time of sample collection (LBDTC)"
    },
    "specimen_type": {
      "type": "string",
      "maxLength": 50,
      "description": "Type of specimen (CDISC CT: SPECIMEN)"
    },
    "lab_name": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Performing laboratory name"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    }
  },
  "additionalProperties": false
}

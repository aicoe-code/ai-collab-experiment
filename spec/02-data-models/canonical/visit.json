{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/visit.json",
  "title": "Visit",
  "description": "A scheduled study visit for a subject. CDISC SDTM domain: SV.",
  "type": "object",
  "required": [
    "visit_id",
    "subject_id",
    "study_id",
    "visit_name",
    "visit_number",
    "scheduled_date",
    "status",
    "visit_type"
  ],
  "properties": {
    "visit_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique visit identifier (PK)"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Subject this visit is for (FK → Subject)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study context (FK → Study)"
    },
    "visit_name": {
      "type": "string",
      "maxLength": 50,
      "description": "Visit label (e.g., V1, V2, Week 4)"
    },
    "visit_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential visit number"
    },
    "scheduled_date": {
      "type": "string",
      "format": "date",
      "description": "Scheduled visit date"
    },
    "actual_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Actual visit date (null if not yet occurred)"
    },
    "status": {
      "type": "string",
      "enum": ["SCHEDULED", "COMPLETED", "MISSED", "CANCELLED"],
      "description": "Visit status"
    },
    "visit_type": {
      "type": "string",
      "enum": ["SCREENING", "BASELINE", "TREATMENT", "FOLLOW_UP", "END_OF_STUDY"],
      "description": "Type of visit (CDISC CT: VISIT)"
    },
    "window_start": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Earliest acceptable visit date"
    },
    "window_end": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Latest acceptable visit date"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp"
    }
  },
  "additionalProperties": false
}

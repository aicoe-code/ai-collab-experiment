{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/subject.json",
  "title": "Subject",
  "description": "A participant enrolled in a study. CDISC SDTM domain: DM.",
  "type": "object",
  "required": [
    "subject_id",
    "study_id",
    "site_id",
    "subject_key",
    "screening_date",
    "status",
    "sex",
    "date_of_birth"
  ],
  "properties": {
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique subject identifier (PK)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study the subject is enrolled in (FK → Study)"
    },
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Site where the subject is enrolled (FK → Site)"
    },
    "subject_key": {
      "type": "string",
      "maxLength": 50,
      "description": "Subject identifier (e.g., CDOS-001-001)"
    },
    "screening_date": {
      "type": "string",
      "format": "date",
      "description": "Date of screening"
    },
    "enrollment_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date of enrollment (null if screen failed)"
    },
    "status": {
      "type": "string",
      "enum": ["SCREENING", "ENROLLED", "COMPLETED", "WITHDRAWN", "SCREEN_FAILED"],
      "description": "Subject status"
    },
    "sex": {
      "type": "string",
      "enum": ["MALE", "FEMALE", "UNKNOWN"],
      "description": "Biological sex (CDISC CT: SEX)"
    },
    "date_of_birth": {
      "type": "string",
      "format": "date",
      "description": "Date of birth"
    },
    "race": {
      "type": ["string", "null"],
      "maxLength": 50,
      "description": "Race (CDISC CT: RACE)"
    },
    "ethnicity": {
      "type": ["string", "null"],
      "maxLength": 50,
      "description": "Ethnicity (CDISC CT: ETHNIC)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp"
    }
  },
  "additionalProperties": false
}

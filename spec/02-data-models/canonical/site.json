{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/site.json",
  "title": "Site",
  "description": "A clinical investigation site. CDISC SDTM domain: DM (as SITEID).",
  "type": "object",
  "required": [
    "site_id",
    "study_id",
    "site_number",
    "name",
    "address",
    "country",
    "status",
    "pi_name"
  ],
  "properties": {
    "site_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique site identifier (PK)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study this site belongs to (FK → Study)"
    },
    "site_number": {
      "type": "string",
      "maxLength": 20,
      "description": "Site identifier (e.g., 001, 002)"
    },
    "name": {
      "type": "string",
      "maxLength": 200,
      "description": "Institution name"
    },
    "address": {
      "type": "string",
      "maxLength": 500,
      "description": "Physical address"
    },
    "country": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "description": "ISO 3166-1 alpha-3 country code"
    },
    "region": {
      "type": ["string", "null"],
      "maxLength": 100,
      "description": "Geographic region"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "ACTIVE", "CLOSED"],
      "description": "Site activation status"
    },
    "pi_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Principal investigator name"
    },
    "pi_email": {
      "type": ["string", "null"],
      "maxLength": 200,
      "format": "email",
      "description": "Principal investigator email"
    },
    "target_enrollment": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Planned enrollment for this site"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp"
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdos.io/schemas/adverse-event.json",
  "title": "AdverseEvent",
  "description": "An adverse event reported for a subject. CDISC SDTM domain: AE.",
  "type": "object",
  "required": [
    "ae_id",
    "subject_id",
    "study_id",
    "term",
    "severity",
    "serious",
    "causality",
    "outcome",
    "onset_date",
    "reported_by"
  ],
  "properties": {
    "ae_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique adverse event identifier (PK)"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "Subject who experienced the AE (FK → Subject)"
    },
    "study_id": {
      "type": "string",
      "format": "uuid",
      "description": "Study context (FK → Study)"
    },
    "term": {
      "type": "string",
      "maxLength": 200,
      "description": "Reported AE term (AETERM)"
    },
    "meddra_code": {
      "type": ["string", "null"],
      "maxLength": 20,
      "description": "Coded MedDRA PT code"
    },
    "meddra_llt": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "MedDRA Lowest Level Term"
    },
    "severity": {
      "type": "string",
      "enum": ["MILD", "MODERATE", "SEVERE"],
      "description": "CTCAE grade (CDISC CT: SEVERITY)"
    },
    "serious": {
      "type": "boolean",
      "description": "Whether the AE is serious (SAE)"
    },
    "serious_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "DEATH",
          "LIFE_THREATENING",
          "HOSPITALIZATION",
          "DISABILITY",
          "CONGENITAL_ANOMALY",
          "IMPORTANT_MEDICAL_EVENT"
        ]
      },
      "uniqueItems": true,
      "description": "Seriousness criteria (required if serious=true)"
    },
    "causality": {
      "type": "string",
      "enum": ["RELATED", "NOT_RELATED", "POSSIBLY_RELATED"],
      "description": "Relatedness to study drug (CDISC CT: RELATIONSHIP)"
    },
    "outcome": {
      "type": "string",
      "enum": ["RECOVERED", "RECOVERING", "NOT_RECOVERED", "FATAL", "UNKNOWN"],
      "description": "AE outcome (CDISC CT: OUTCOME)"
    },
    "onset_date": {
      "type": "string",
      "format": "date",
      "description": "Date of AE onset (AESTDTC)"
    },
    "resolution_date": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Date of AE resolution (AEENDTC, null if ongoing)"
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 2000,
      "description": "Narrative description"
    },
    "reported_by": {
      "type": "string",
      "maxLength": 100,
      "description": "Who reported the AE"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Record last update timestamp"
    }
  },
  "additionalProperties": false
}
